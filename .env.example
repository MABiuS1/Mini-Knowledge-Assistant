# App
APP_ENV=development
PORT=8080
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_MAX_UPLOAD_BYTES=10485760
API_PROXY_TARGET=
REQUEST_TIMEOUT_SECONDS=30

# Auth
JWT_SECRET=change-me-in-local-env
SESSION_TTL_HOURS=24

# Database
POSTGRES_USER=knowledge
POSTGRES_PASSWORD=knowledge
POSTGRES_DB=knowledge_assistant
POSTGRES_PORT=15432
DATABASE_URL=postgres://knowledge:knowledge@postgres:5432/knowledge_assistant?sslmode=disable
MIGRATIONS_DIR=/app/migrations

# AI provider
AI_PROVIDER=gemini
AI_BASE_URL=https://generativelanguage.googleapis.com
AI_API_KEY=replace-with-your-key
AI_MODEL=gemini-2.5-flash

# Embeddings
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com
EMBEDDING_API_KEY=replace-with-your-key
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536

# Uploads
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_BYTES=10485760
